# E2E test environment — copy to .env.e2e and fill in values
# NEVER commit .env.e2e — it contains real private keys

# Private key for pre-funded testnet wallet (Sepolia + Arb Sepolia)
E2E_PRIVATE_KEY=0x...

# CrossCurve API
E2E_API_BASE_URL=https://api.crosscurve.fi
E2E_API_KEY=test-sdk-test-sdk-test-sdk-standard

# Alchemy RPC (for reliable Sepolia/Arb Sepolia access)
E2E_ALCHEMY_API_KEY=...
