# Test environment configuration
# Copy this file to .env.test and fill in the values

# API configuration
TEST_API_BASE_URL=https://api.crosscurve.fi

# Test wallet configuration (required for E2E swap tests)
# Generate a fresh mnemonic for testing purposes
# NEVER commit real wallet mnemonics
TEST_MNEMONIC=your-test-mnemonic-here

# The wallet address derived from the mnemonic (for reference)
TEST_WALLET_ADDRESS=

# Enable real swap tests (set to 'true' to run transaction tests)
ENABLE_E2E_SWAP=false
